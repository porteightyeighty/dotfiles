# Set the directory we want to store zinit and plugins
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"


# Download Zinit, if it's not there 
if [ ! -d "$ZINIT_HOME" ]; then
  mkdir -p "$(dirname $ZINIT_HOME)"
  git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi 

source "${ZINIT_HOME}/zinit.zsh"

# plugins

zinit light lukechilds/zsh-nvm

# zsh-completions must be sourced before compinit so its definitions land on $fpath
zinit light zsh-users/zsh-completions

# Initialize the completion system. This is what powers `tmux <Tab>` -> kill-session, ls, ...
autoload -Uz compinit && compinit

# fzf-tab must load AFTER compinit and BEFORE widget-wrapping plugins
# (zsh-autosuggestions / zsh-syntax-highlighting), otherwise the menu can misbehave.
zinit light Aloxaf/fzf-tab

zinit light zsh-users/zsh-autosuggestions

zinit ice depth=2
zinit light jeffreytse/zsh-vi-mode

# zsh-syntax-highlighting MUST be the last plugin sourced.
zinit light zsh-users/zsh-syntax-highlighting

# Let inline autosuggestions fall back to the completion engine, so subcommands
# (e.g. `tmux kill-session`) are suggested even when they're not yet in history.
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

#Completion styling 
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
# Persist command history
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000000
SAVEHIST=$HISTSIZE
HISTORY_IGNORE="(ls|cd|pwd|exit|cd)*"

#Vim Keybindings
bindkey -v 

setopt EXTENDED_HISTORY      # Write the history file in the ':start:elapsed;command' format.
setopt INC_APPEND_HISTORY    # Write to the history file immediately, not when the shell exits.
setopt SHARE_HISTORY         # Share history between all sessions.
setopt HIST_IGNORE_DUPS      # Do not record an event that was just recorded again.
setopt HIST_IGNORE_ALL_DUPS  # Delete an old recorded event if a new event is a duplicate.
setopt HIST_IGNORE_SPACE     # Do not record an event starting with a space.
setopt HIST_SAVE_NO_DUPS     # Do not write a duplicate event to the history file.
setopt HIST_VERIFY           # Do not execute immediately upon history expansion.
setopt APPEND_HISTORY        # append to history file (Default)
setopt HIST_NO_STORE         # Don't store history commands
setopt HIST_REDUCE_BLANKS    # Remove superfluous blanks from each command line being added to the history.

# Environment

export EDITOR=nvim
export VISUAL=nvim

# Aliases

alias ls='ls --color'
alias l='ls -lAh --color'

# Rebuild/activate the home-manager config (impure: username is read from $USER)
alias hms='home-manager switch -b backup --flake ~/dotfiles#default --impure'


# Functions

# Open yazi with `y`; cd into the directory yazi was in on quit.
function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    command yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd < "$tmp"
    [ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
    command rm -f -- "$tmp"
}


# Auto (de)activate a Python venv based on the current directory.
# Walks up from $PWD looking for a `.venv`; activates it on entry and
# deactivates when you leave the project tree (or move to one without a venv).
function _auto_venv() {
    local dir="$PWD" found=""
    while [[ "$dir" != "/" && -n "$dir" ]]; do
        if [[ -f "$dir/.venv/bin/activate" ]]; then
            found="$dir/.venv"
            break
        fi
        dir="${dir:h}"
    done

    if [[ -n "$found" ]]; then
        # Activate (or switch) if it isn't the currently active venv.
        if [[ "$VIRTUAL_ENV" != "$found" ]]; then
            [[ -n "$VIRTUAL_ENV" ]] && deactivate >/dev/null 2>&1
            source "$found/bin/activate"
        fi
        # Always re-assert the venv's bin at the front of PATH. When the venv is
        # inherited from a parent shell (VIRTUAL_ENV already set), the branch
        # above is skipped, so the ~/.nix-profile/bin prepend would otherwise
        # shadow the venv's python. Strip any existing entry, then re-prepend.
        path=("$found/bin" ${path:#$found/bin})
    elif [[ -n "$VIRTUAL_ENV" ]]; then
        # Left the project tree: deactivate.
        deactivate >/dev/null 2>&1
    fi
}

# Nix (home-manager) profile takes precedence over system & Homebrew tools.
# macOS path_helper pushes ~/.nix-profile/bin to the back of PATH; re-prepend it
# here so nix-provided binaries win for interactive shells.
export PATH="$HOME/.nix-profile/bin:$HOME/.local/bin:$PATH"

#Shell integrations

eval "$(fzf --zsh)"

eval "$(starship init zsh)"

