  "Trigger Scaffold": {
    "prefix": "trigger",
    "body": [
      "trigger ${1:TriggerName} on ${2:SObject} (before insert, before update, after insert, after update) {",
      "\tif (Trigger.isBefore) {",
      "\t\tif (Trigger.isInsert) {",
      "\t\t\t${3:// before insert logic}",
      "\t\t}",
      "\t\tif (Trigger.isUpdate) {",
      "\t\t\t${4:// before update logic}",
      "\t\t}",
      "\t}",
      "\tif (Trigger.isAfter) {",
      "\t\tif (Trigger.isInsert) {",
      "\t\t\t${5:// after insert logic}",
      "\t\t}",
      "\t\tif (Trigger.isUpdate) {",
      "\t\t\t${0:// after update logic}",
      "\t\t}",
      "\t}",
      "}"
    ],
    "description": "Trigger with before/after handlers"
  },
